{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-gemini-auth@latest"],
  "provider": { "google": {} },
  "permission": {
    "*": "ask",
    "edit": "ask",
    "bash": {
      "*": "ask",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "grep *": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "cat *": "allow"
    },
    "external_directory": {
      "/srv/repos/**": "allow",
      "**": "ask"
    }
  },
  "model": "google/gemini-2.5-flash",
  "small_model": "google/gemini-2.0-flash",
  "server": { "hostname": "127.0.0.1", "port": 4096 }
}
